# %% [markdown]
# # 1D Heat Conduction with Generalized Finite Difference Schemes
#
# This notebook solves the 1D heat conduction (diffusion) equation:
# $$ \frac{\partial T}{\partial t} = \alpha \frac{\partial^2 T}{\partial x^2} $$
#
# A generalized `beta` formulation is used, which allows for switching between different numerical schemes:
# - **Explicit FTCS** (`beta = 0`): Conditionally stable.
# - **Crank-Nicolson** (`beta = 0.5`): Unconditionally stable, second-order accurate in time.
# - **Laasonen (Fully Implicit)** (`beta = 1.0`): Unconditionally stable, first-order accurate in time.
#
# ### Problem Setup
# - **Domain:** A 1D rod of length `L`.
# - **Initial Condition:** The temperature is 0 everywhere: `T(x, t=0) = 0`.
# - **Boundary Conditions:** For `t > 0`, the left end is held at `T=1` and the right end at `T=0`.

# %%
# Import necessary libraries
import numpy as np
import matplotlib.pyplot as plt
import os

# %% [markdown]
# ## 1. Input and Scheme Parameters
#
# Here, you can define the physical properties of the domain, the discretization (grid and time step), and select the numerical scheme by setting the `beta` parameter.

# %%
# --- Physical and Discretization Parameters ---
l = 1.0  # Length of the domain in meters
alpha = 1.0  # Thermal diffusivity
nodes = 11  # Number of grid points
dt = 0.01  # Time step size. NOTE: A large dt (e.g., > 0.005 for beta=0) can cause instability.
total_time = 2.0  # Total simulation time

# --- Scheme Selection ---
# beta = 0   -> Explicit FTCS (Conditionally Stable)
# beta = 0.5 -> Crank-Nicolson (Unconditionally Stable)
# beta = 1.0 -> Laasonen / Fully Implicit (Unconditionally Stable)
beta = 0.5

# %% [markdown]
# ## 2. Derived Parameters and Stability Check
#
# The code calculates derived parameters like grid spacing (`dx`) and the diffusion number (`gamma`). It also performs a stability check for the chosen scheme.

# %%
# --- Derived Parameters ---
dx = l / (nodes - 1)  # Grid spacing
gamma = alpha * dt / dx**2  # Diffusion number
num_steps = int(total_time / dt)  # Number of time steps

# --- Scheme Name and Stability Check ---
scheme_map = {
    0: "Explicit FTCS",
    0.5: "Crank-Nicolson",
    1.0: "Laasonen",
}
scheme_name = scheme_map.get(beta, f"Generalized (beta={beta})")

# Stability condition for 0 <= beta < 0.5 is gamma <= 1 / (2 * (1 - 2*beta))
if 0 <= beta < 0.5:
    stability_limit = 1 / (2 * (1 - 2 * beta))
    if gamma > stability_limit:
        print(
            f"WARNING: Stability for {scheme_name} (gamma <= {stability_limit:.2f}) is VIOLATED. Current gamma = {gamma:.3f}"
        )
    else:
        print(f"Running with {scheme_name}. Stability condition is met (gamma = {gamma:.3f}).")
else:
    print(f"Running with {scheme_name} (gamma = {gamma:.3f}), which is unconditionally stable.")

# %% [markdown]
# ## 3. Initialization
#
# We set up the spatial grid, define the initial temperature distribution `T(x, t=0) = 0`, and prepare an array `T_history` to store the temperature at each time step.

# %%
# Times at which to plot the solution
time_plot = np.array([0, 0.002, 0.01, 0.05, 0.1, 0.25, 0.5, 1.0, 2.0])

# Spatial coordinates and initial temperature T(x, t=0) = 0
x = np.linspace(0, l, nodes)
T = np.zeros(nodes)

# Array to store temperature history, starting with the initial condition
T_history = np.zeros((num_steps + 1, nodes))
T_history[0] = T.copy()

# Boundary conditions for t > 0
T_bc_left = 1.0
T_bc_right = 0.0

# Apply BCs to the working temperature array `T` which will evolve over time
T[0] = T_bc_left
T[-1] = T_bc_right

# %% [markdown]
# ## 4. Time-Stepping Loop
#
# This is the core of the solver. It iterates through time, calculating the temperature distribution at each step using the selected scheme. For implicit schemes (`beta > 0`), this involves solving a tridiagonal system of linear equations at each time step.

# %%
for n in range(1, num_steps + 1):
    T_old = T.copy()

    if beta == 0:  # Explicit FTCS
        # Update interior nodes based on the previous time step's values
        T[1:-1] = T_old[1:-1] + gamma * (T_old[2:] - 2 * T_old[1:-1] + T_old[:-2])
    else:  # Implicit schemes (beta > 0)
        num_interior_nodes = nodes - 2
        
        # Setup the tridiagonal matrix A for the LHS of the system
        main_diag = np.full(num_interior_nodes, 1 + 2 * beta * gamma)
        off_diag = np.full(num_interior_nodes - 1, -beta * gamma)
        A = np.diag(main_diag) + np.diag(off_diag, k=1) + np.diag(off_diag, k=-1)

        # Setup the RHS vector b, which depends on the previous time step
        rhs_explicit_part = (1 - beta) * gamma * (T_old[2:] - 2 * T_old[1:-1] + T_old[:-2])
        b = T_old[1:-1] + rhs_explicit_part
        
        # Modify RHS to account for the boundary conditions of the NEW time step
        b[0] += beta * gamma * T_bc_left
        b[-1] += beta * gamma * T_bc_right

        # Solve the linear system A * T_new = b for the interior nodes
        T[1:-1] = np.linalg.solve(A, b)
        # The boundary nodes of T are already set and remain constant

    # Store the newly computed temperature profile
    T_history[n] = T.copy()

print("Simulation finished.")

# %% [markdown]
# ## 5. Plotting Results
#
# Finally, we define a function to plot the temperature distribution at different points in time and visualize the results.

# %%
def plot_temperature_distribution(x_coords, T_history, time_points, dt, gamma, scheme_name, output_filename):
    """Plots the temperature distribution at specified time points."""
    plt.style.use("seaborn-v0_8-whitegrid")
    fig, ax = plt.subplots(figsize=(12, 7))
    colors = plt.cm.viridis(np.linspace(0, 1, len(time_points)))

    for i, t in enumerate(time_points):
        step_index = int(round(t / dt))
        if step_index < T_history.shape[0]:
            ax.plot(x_coords, T_history[step_index], marker='o', markersize=4, linestyle='-', color=colors[i], label=f"t = {t:.3f} s")

    ax.set_xlabel("Position (m)", fontsize=12)
    ax.set_ylabel("Temperature", fontsize=12)
    ax.set_title(f"1D Heat Conduction ({scheme_name}) | $\Delta t$ = {dt} s | $\gamma$ = {gamma:.3f}", fontsize=14, fontweight='bold')
    ax.legend(title="Time", fontsize=10)
    ax.grid(True, which='both', linestyle='--', linewidth=0.5)
    
    # Create directory for plots if it doesn't exist
    output_dir = os.path.dirname(output_filename)
    if not os.path.exists(output_dir):
        os.makedirs(output_dir)
        
    plt.savefig(output_filename, dpi=300, bbox_inches='tight')
    print(f"Plot saved successfully as: {output_filename}")
    plt.show()

# --- Execution ---
output_dir = "plots"
figname = f"temp_dist_{scheme_name.replace(' ', '_')}_dt_{dt}.png"
plot_path = os.path.join(output_dir, figname)

plot_temperature_distribution(x, T_history, time_plot, dt, gamma, scheme_name, plot_path)